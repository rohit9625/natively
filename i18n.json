{
  "$schema": "https://lingo.dev/schema/i18n.json",
  "version": "1.12",
  "locale": {
    "source": "en",
    "targets": [
      "hi", "es", "fr", "de", "ja", "zh", "ko", "pt", "it", "ru"
    ]
  },
  "buckets": {
    "android": {
      "include": ["app/src/main/res/values-[locale]/strings.xml"]
    }
  }
}